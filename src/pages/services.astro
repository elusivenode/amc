---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const ctaHref = 'mailto:hamish@australianmathcoach.com';
---

<Layout
  title="Programs | Australian Math Coach"
  description="Two focused pathways: build strong maths foundations or pursue advanced problem-solving and competition preparation."
  showCornerLogo={false}
>
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-4">Programs</h1>
      <p class="text-xl text-blue-800 font-medium max-w-3xl mx-auto">
        Two pathways depending on your child&apos;s goals and interest in maths.
      </p>
    </div>
  </section>

  <section class="pb-16 md:pb-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <article class="rounded-2xl bg-white border border-slate-200 shadow-sm p-6 md:p-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-6">Build strong maths foundations</h2>

          <div class="space-y-5 text-slate-700">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">Who it&apos;s for</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Students who want to improve understanding and performance in school maths</li>
                <li>Students lacking confidence or clarity</li>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">What&apos;s included</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Core concepts explained clearly</li>
                <li>Problem-solving techniques</li>
                <li>Exam and test preparation</li>
                <li>Small group or 1:1 sessions</li>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">Outcome</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Better understanding</li>
                <li>Improved confidence</li>
                <li>Stronger results in school assessments</li>
              </ul>
            </div>
          </div>

          <div class="mt-8">
            <a
              href={ctaHref}
              class="inline-flex items-center justify-center rounded-lg bg-[#204585] px-6 py-3 text-base font-semibold text-white hover:bg-[#1a3a70] transition-colors"
            >
              Book a free session
            </a>
          </div>
        </article>

        <article class="rounded-2xl bg-white border border-slate-200 shadow-sm p-6 md:p-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-6">Advanced problem-solving &amp; competitions</h2>

          <div class="space-y-5 text-slate-700">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">Who it&apos;s for</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Students who enjoy maths and want to go deeper</li>
                <li>Students preparing for AMC and beyond</li>
                <li>Students aiming for distinction / AIMO pathway</li>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">What&apos;s included</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Structured problem-solving training</li>
                <li>AMC-style questions and strategies</li>
                <li>Mathematical reasoning and pattern recognition</li>
                <li>Preparation for higher-level competitions</li>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-blue-800 mb-2">Outcome</h3>
              <ul class="space-y-2 leading-relaxed">
                <li>Strong problem-solving ability</li>
                <li>Competition readiness</li>
                <li>Advanced mathematical thinking</li>
              </ul>
            </div>
          </div>

          <div class="mt-8">
            <a
              href="/extension-amc"
              class="inline-flex items-center justify-center rounded-lg border border-[#204585] px-6 py-3 text-base font-semibold text-[#204585] hover:bg-blue-50 transition-colors"
            >
              Explore extension maths
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <CTASection
    title="Start with a free first session"
    description="The first session is a chance to understand your child&apos;s current thinking, goals and whether this style of coaching is a good fit."
    ctaLabel="Book a free session"
    ctaHref={ctaHref}
  />
</Layout>