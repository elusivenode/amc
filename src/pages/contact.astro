---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const ctaHref = 'mailto:hamish@australianmathcoach.com';
---

<Layout
  title="Contact | Australian Math Coach"
  description="Get in touch with Australian Math Coach to discuss your child’s goals and book a free first session."
  showCornerLogo={false}
>
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-4">Get in touch</h1>
        <p class="text-xl text-blue-800 font-medium leading-relaxed">
          Ready to improve your child&apos;s mathematical thinking and confidence? Reach out to book a free first session.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16 md:pb-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <article class="rounded-2xl bg-white border border-slate-200 shadow-sm p-6 md:p-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-6">Contact information</h2>

          <div class="space-y-6 text-slate-700">
            <div>
              <h3 class="text-base font-semibold text-slate-900 mb-1">Phone</h3>
              <p class="text-lg mb-1">
                <a href="tel:+61418764798" class="text-[#204585] hover:text-[#1a3a70] transition-colors">0418 764 798</a>
              </p>
              <p class="text-sm text-slate-600 leading-relaxed">
                Monday to Friday: 9:00 AM - 6:00 PM
                <br />
                Saturday and Sunday: 8:00 AM - 8:00 PM
              </p>
            </div>

            <div>
              <h3 class="text-base font-semibold text-slate-900 mb-1">Email</h3>
              <p class="text-lg mb-1">
                <a href={ctaHref} class="text-[#204585] hover:text-[#1a3a70] transition-colors">hamish@australianmathcoach.com</a>
              </p>
              <p class="text-sm text-slate-600">Replies within 24 hours</p>
            </div>

            <div>
              <h3 class="text-base font-semibold text-slate-900 mb-1">Location</h3>
              <p class="text-lg text-slate-700 leading-relaxed mb-1">
                6 Turner Street
                <br />
                Corinda, Brisbane Q4075
                <br />
                Australia
              </p>
              <p class="text-sm text-slate-600">In-person tutoring available for local students</p>
            </div>
          </div>
        </article>

        <article class="rounded-2xl bg-slate-50 border border-slate-200 shadow-sm p-6 md:p-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-6">Send a message</h2>

          <form
            class="space-y-5"
            action="https://formsubmit.co/hamish@australianmathcoach.com"
            method="POST"
            target="_blank"
          >
            <input type="hidden" name="_subject" value="Australian Math Coach enquiry" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Full Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email Address *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors" />
              </div>
              <div>
                <label for="level" class="block text-sm font-medium text-slate-700 mb-2">Student Pathway</label>
                <select id="level" name="level" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors">
                  <option value="">Select pathway</option>
                  <option value="foundations">Build strong maths foundations</option>
                  <option value="extension">Advanced problem-solving and competitions</option>
                  <option value="not-sure">Not sure yet</option>
                </select>
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">Subject of Interest</label>
              <select id="subject" name="subject" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors">
                <option value="">Select subject</option>
                <option value="school-support">School maths support</option>
                <option value="exam-prep">Exam preparation</option>
                <option value="amc-extension">Extension and AMC preparation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell me about your child&apos;s goals, current challenges, and what support you&apos;re looking for." class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors resize-none"></textarea>
            </div>

            <button type="submit" class="w-full inline-flex items-center justify-center rounded-lg bg-[#204585] px-6 py-3 text-base font-semibold text-white hover:bg-[#1a3a70] transition-colors">
              Send message
            </button>
          </form>
        </article>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-8">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-4">Frequently asked questions</h2>
        <p class="text-lg text-slate-700 leading-relaxed">
          A few common questions from parents before getting started.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <article class="rounded-2xl bg-white border border-slate-200 p-6 shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 mb-2">How much do sessions cost?</h3>
          <p class="text-slate-700">Pricing depends on year level and session type. The first session is free. <a href={ctaHref} class="text-[#204585] hover:text-[#1a3a70]">Email Hamish</a> for current options.</p>
        </article>
        <article class="rounded-2xl bg-white border border-slate-200 p-6 shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Do you offer online sessions?</h3>
          <p class="text-slate-700">Yes. Sessions are available online and in person for local families, depending on what suits your child best.</p>
        </article>
        <article class="rounded-2xl bg-white border border-slate-200 p-6 shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 mb-2">How do we book the first session?</h3>
          <p class="text-slate-700">Send a message through this page, call, or email. We&apos;ll discuss goals and book a free first session.</p>
        </article>
        <article class="rounded-2xl bg-white border border-slate-200 p-6 shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Are sessions 1:1 or group based?</h3>
          <p class="text-slate-700">Both are available depending on the student&apos;s goals, level, and preferred learning style.</p>
        </article>
      </div>
    </div>
  </section>

  <CTASection
    title="Start with a free first session"
    description="The first session is a chance to understand your child&apos;s current thinking, goals and whether this style of coaching is a good fit."
    ctaLabel="Book a free session"
    ctaHref={ctaHref}
  />
</Layout>
