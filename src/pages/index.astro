---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTASection from '../components/CTASection.astro';

const ctaHref = 'mailto:hamish@australianmathcoach.com';
---

<Layout
  title="Australian Math Coach | Learn how to think in maths"
  description="Structured online maths coaching for Years 5-12. Problem-solving, extension maths, and AMC preparation."
  showCornerLogo={false}
>
  <HeroSection />

  <section class="py-16 md:py-20 bg-white" id="intro">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-5">
          Maths coaching focused on how students think
        </h2>
        <p class="text-lg text-slate-700 leading-relaxed">
          Australian Math Coach helps students build deeper understanding, stronger problem-solving habits, and confidence with unfamiliar maths problems. Sessions are online-first and available as small-group or 1:1 coaching.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white" id="services">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-10 md:mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-4">Services and pathways</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="rounded-2xl bg-white p-6 shadow-sm border border-slate-100 flex flex-col">
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Online Maths Coaching</h3>
          <p class="text-slate-700 leading-relaxed mb-6">For students who want clearer understanding, stronger foundations, and better confidence in school maths.</p>
          <a href="/coaching" class="mt-auto inline-flex items-center justify-center rounded-lg bg-blue-50 text-blue-800 font-semibold px-4 py-2 hover:bg-blue-100 transition-colors">Learn about coaching</a>
        </article>
        <article class="rounded-2xl bg-white p-6 shadow-sm border border-slate-100 flex flex-col">
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Extension &amp; AMC Preparation</h3>
          <p class="text-slate-700 leading-relaxed mb-6">For students who enjoy maths and want to develop problem-solving strategies for competitions such as the AMC.</p>
          <a href="/extension-amc" class="mt-auto inline-flex items-center justify-center rounded-lg bg-blue-50 text-blue-800 font-semibold px-4 py-2 hover:bg-blue-100 transition-colors">Explore extension maths</a>
        </article>
        <article class="rounded-2xl bg-white p-6 shadow-sm border border-slate-100 flex flex-col md:col-span-2 lg:col-span-1">
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Small Groups &amp; 1:1 Support</h3>
          <p class="text-slate-700 leading-relaxed mb-6">Flexible support through small online groups or focused individual sessions.</p>
          <a href="/sessions" class="mt-auto inline-flex items-center justify-center rounded-lg bg-blue-50 text-blue-800 font-semibold px-4 py-2 hover:bg-blue-100 transition-colors">See session options</a>
        </article>
      </div>
    </div>
  </section>

  <section id="contact">
    <CTASection
      title="Start with a free first session"
      description="The first session is a chance to understand your child&apos;s current thinking, goals, and whether this style of coaching is a good fit."
      ctaLabel="Book a free session"
      ctaHref={ctaHref}
    />
  </section>
</Layout>
