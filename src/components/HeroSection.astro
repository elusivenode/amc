---
const ctaHref = 'mailto:hamish@australianmathcoach.com';
---

<section class="pt-8 pb-14 md:pt-10 md:pb-16" id="hero">
  <div class="max-w-6xl mx-auto px-6">
    <div class="space-y-6 md:space-y-8">
      <div class="rounded-3xl overflow-hidden shadow-lg bg-white">
        <img
          src="/images/brand/AustralianMathCoach-banner.png"
          alt="Australian Math Coach learning banner"
          class="w-full h-full object-cover min-h-[260px] md:min-h-[360px]"
        />
      </div>

      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight mb-5">
          Learn how to think in maths
        </h1>
        <p class="text-lg text-slate-700 leading-relaxed max-w-2xl mb-8">
          Structured coaching for Years 5-12. Problem-solving, extension and AMC preparation.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaHref} class="inline-flex items-center justify-center rounded-lg bg-[#204585] text-white font-semibold px-8 py-3 hover:bg-[#1a3a70] transition-colors shadow-sm">
            Book a free session
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-3 rounded-lg border border-slate-300 text-slate-700 font-semibold hover:bg-slate-50 transition-colors">
            How it works
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
