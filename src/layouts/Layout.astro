---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

export interface Props {
  title: string;
  description?: string;
  showCornerLogo?: boolean;
}

const {
  title,
  description = "Professional math tutoring services in Australia. Expert guidance for students of all levels.",
  showCornerLogo = true
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-slate-900 bg-slate-50">
    <SiteHeader />
    {
      showCornerLogo && (
        <div class="fixed top-20 right-4 z-40 pointer-events-none" aria-hidden="true">
          <img
            src="/images/brand/AustralianMathCoach-logo.png"
            alt=""
            class="w-72 md:w-96 h-auto opacity-95 drop-shadow-sm"
          />
        </div>
      )
    }
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
